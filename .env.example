# DIGIRINGO — environment config
# Copy to ".env" and fill in. Vite only exposes vars prefixed with VITE_ to the app.

# Telnyx integration mode: "mock" (no backend needed) or "live"
VITE_TELNYX_MODE=mock

# Base path the app calls in live mode. This must point at YOUR backend proxy,
# NOT api.telnyx.com (the secret key must never reach the browser).
VITE_API_BASE=/api/telnyx

# Optional defaults used when ordering numbers / sending SMS in live mode
VITE_TELNYX_MESSAGING_PROFILE_ID=
VITE_TELNYX_CONNECTION_ID=

# ---- SERVER-SIDE ONLY (used by server/telnyx-proxy.mjs, never by the app) ----
# Your Telnyx V2 API key. KEEP SECRET. Do not prefix with VITE_.
TELNYX_API_KEY=KEY_xxxxxxxxxxxxxxxxxxxxxxxx
# Port the proxy listens on
TELNYX_PROXY_PORT=8787

# ---- Freemius (Merchant of Record) — payments. SERVER-SIDE ONLY. ----
# From your Freemius product dashboard. The PRODUCT_ID + PUBLIC_KEY are served to
# the browser at runtime (GET /api/freemius/config) so changing ids needs NO
# frontend rebuild. The SECRET_KEY signs webhooks + never reaches the browser.
FREEMIUS_PRODUCT_ID=
FREEMIUS_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxx
FREEMIUS_SECRET_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
# Map each DIGIRINGO product to its Freemius plan/pricing ids (single source of
# truth: the browser opens the right checkout, the webhook fulfils by pricing_id).
# Key format: "bundle:<tier>:<cycle>" or "topup:<amount>". Fill after creating
# the plans + top-up packs. Example (replace the ids):
# FREEMIUS_CHECKOUTS={"bundle:starter:monthly":{"plan_id":"111","pricing_id":"222"},"bundle:starter:annual":{"plan_id":"111","pricing_id":"223"},"bundle:business:monthly":{"plan_id":"112","pricing_id":"224"},"bundle:business:annual":{"plan_id":"112","pricing_id":"225"},"bundle:pro:monthly":{"plan_id":"113","pricing_id":"226"},"bundle:pro:annual":{"plan_id":"113","pricing_id":"227"},"topup:5":{"plan_id":"120","pricing_id":"230"},"topup:10":{"plan_id":"121","pricing_id":"231"},"topup:20":{"plan_id":"122","pricing_id":"232"},"topup:50":{"plan_id":"123","pricing_id":"233"}}
FREEMIUS_CHECKOUTS={}
